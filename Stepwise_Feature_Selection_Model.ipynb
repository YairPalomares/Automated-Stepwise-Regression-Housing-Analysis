    "import math\n",
    "import scipy.stats\n",
    "\n",
    "bandera = 0\n",
    "while bandera == 0:\n",
    "    #Definir las matrices Xdata y Ydata\n",
    "    Xdata = data_house.drop(columns = ['price']).values\n",
    "    Ydata = data_house[[\"price\"]].values\n",
    "    \n",
    "    #Dividir en bases de entrenamiento y prueba\n",
    "    from sklearn.model_selection import train_test_split\n",
    "    x_train, x_test, y_train, y_test = train_test_split(Xdata, Ydata, test_size = 0.3, random_state = 1)\n",
    "    \n",
    "    x = x_train\n",
    "    y = y_train\n",
    "    \n",
    "    #Operaciones para obtener la matriz b\n",
    "    XT_X = np.matmul(np.matrix.transpose(x), x)\n",
    "    XT_X_inv = np.linalg.inv(XT_X)\n",
    "    \n",
    "    XT_Y = np.matmul(np.matrix.transpose(x), y)\n",
    "    betas = np.matmul(XT_X_inv, XT_Y)\n",
    "    \n",
    "    #Predicciones\n",
    "    Y_pred = x @ betas\n",
    "    \n",
    "    #Residuales\n",
    "    Resid = y - Y_pred\n",
    "    \n",
    "    #RSS\n",
    "    RSS = np.sum(Resid**2)\n",
    "    \n",
    "    #TSS\n",
    "    TSS = np.sum((y - y.mean())**2)\n",
    "    \n",
    "    #R2\n",
    "    RSq = 1 - RSS/TSS\n",
    "    print(\"Coeficiente de determinación R cuadrada =\", RSq)\n",
    "    \n",
    "    #R2 ajustada\n",
    "    n = x.shape[0]\n",
    "    p = x.shape[1]\n",
    "    \n",
    "    RSqAj = 1 - (RSS/(n-p))/(TSS/(n-1))\n",
    "    print(\"Coeficiente de determinación R cuadrada ajustada =\", RSqAj)\n",
    "    \n",
    "    #Cálculo de la varianza del error de regresión\n",
    "    s_cuad = RSS / (len(y) - x.shape[1])\n",
    "\n",
    "    #Cálculo de la desviación estándar del error de regresión\n",
    "    s = math.sqrt(s_cuad)\n",
    "    \n",
    "    # Cálculo de las t's estadísticas para cada coeficiente de regresión\n",
    "    result_t = []\n",
    "    for i in range(x.shape[1]):\n",
    "        t = float(betas[i] / (s * math.sqrt(XT_X_inv[i][i])))\n",
    "        result_t.append(t)\n",
    "    \n",
    "    grados_libertad = len(y) - x.shape[1]\n",
    "    #La t_critica se obtendrá a un nivel de confianza del 95% (Alfa = 5%)\n",
    "    t_critico = abs(scipy.stats.t.ppf(q = 0.025, df = grados_libertad))\n",
    "    print(\"Valor crítico de t\", t_critico)\n",
    "    \n",
    "    variables_no_significativas = []\n",
    "    for i in range(x.shape[1]):\n",
    "        if (abs(result_t[i]) > t_critico):\n",
    "            print(\"Beta\", i, \"es significativa\") #Aquí se rechaza la hipótesis nula\n",
    "        else:\n",
    "            print(\"Beta\", i, \"NO es significativa\") #Aquí NO se rechaza la hipótesis nula\n",
    "            if i != 0:\n",
    "                variables_no_significativas.append(i)\n",
    "    \n",
    "    if len(variables_no_significativas) > 0:\n",
    "        #Cálculo de valores p\n",
    "        valores_p = []\n",
    "        for i in range(len(variables_no_significativas)):\n",
    "            p = scipy.stats.t.sf(abs(result_t[variables_no_significativas[i]]), df = grados_libertad) * 2\n",
    "            print(\"Valor p de Beta\", variables_no_significativas[i], \":\", p)\n",
    "            valores_p.apend(p)\n",
    "        index_mayor_p = valores_p.index(max(valores_p))\n",
    "        variables_independientes = data_house.drop(columns = ['price']).columns\n",
    "        data_house = data_house.drop(columns = [variables_independientes[variables_no_significativas[index_mayor_p]]])\n",
    "        print(\"Se elimina la variable\", variables_independientes[variables_no_significativas[index_mayor_p]])\n",
    "    else:\n",
    "        bandera = 1\n",
    "\n",
    "    print(\"Las variables independientes del modelo son:\", data_house.drop(columns = ['price']).columns)\n",
    "    print(\"-----------------------------------------\")\n"
   ]
  },
