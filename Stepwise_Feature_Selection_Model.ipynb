   "source": [
    "#Se lee la base de datos y se convierte en dataframe\n",
    "data_house = pd.read_csv(\"kc_house_data.csv\")\n",
    "data_house"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 123,
   "id": "cbe7c7e6-ac3f-4901-9e6e-2779955d88f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Limpieza de datos\n",
    "\n",
    "#Se eliminan del dataframe las variables de id y zipcode. Ya que estas no son características directas con la casa\n",
    "data_house = data_house.drop(columns=['id', 'zipcode'])\n",
    "\n",
    "#Se toma el año de venta de la columna date, se convierte a int despues\n",
    "data_house['date'] = data_house['date'].str[:4]\n",
    "data_house['date'] = data_house['date'].astype(int)\n",
    "\n",
    "#Se crea columna de antiguedad de la casa\n",
    "data_house[\"yr_antique\"] = data_house[\"date\"] - data_house[\"yr_built\"]\n",
    "\n",
    "#Se eliminan las columnas de \"date\" y \"yr_built\"\n",
    "data_house = data_house.drop(columns = [\"date\", \"yr_built\"])\n",
    "\n",
    "#Agregando la variable de 1 para el intercepto\n",
    "data_house.insert(0, 'Intercepto', 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 104,
   "id": "c249954e-fdf7-44c0-87af-cb9816529d1c",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Opción de formato numérico para evitar que se coloquen decimales con notación científica\n",
    "np.set_printoptions(formatter={\"float_kind\":\"{:f}\".format})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 83,
   "id": "09b2104b-ea5a-4b8a-94f8-d07fcac04a0f",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Definir las matrices Xdata y Ydata\n",
    "Xdata = data_house.drop(columns = ['price']).values\n",
    "Ydata = data_house[[\"price\"]].values\n",
    "\n",
    "#Dividir en bases de entrenamiento y prueba\n",
    "from sklearn.model_selection import train_test_split\n",
    "x_train, x_test, y_train, y_test = train_test_split(Xdata, Ydata, test_size = 0.3, random_state = 1)\n",
    "\n",
    "x = x_train\n",
    "y = y_train"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 84,
   "id": "65f87638-7466-4eec-97f5-a24133601d50",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Coeficiente de determinación R cuadrada = -128.8903328008599\n",
      "Coeficiente de determinación R cuadrada ajustada = -129.03646049972926\n"
     ]
    }
   ],
   "source": [
    "#Operaciones para obtener la matriz b\n",
    "XT_X = np.matmul(np.matrix.transpose(x), x)\n",
    "XT_X_inv = np.linalg.inv(XT_X)\n",
    "\n",
    "XT_Y = np.matmul(np.matrix.transpose(x), y)\n",
    "betas = np.matmul(XT_X_inv, XT_Y)\n",
    "\n",
    "#Predicciones\n",
    "Y_pred = x @ betas\n",
    "\n",
    "#Residuales\n",
    "Resid = y - Y_pred\n",
    "\n",
    "#RSS\n",
    "RSS = np.sum(Resid**2)\n",
    "\n",
    "#TSS\n",
    "TSS = np.sum((y - y.mean())**2)\n",
    "\n",
    "#R2\n",
    "RSq = 1 - RSS/TSS\n",
    "print(\"Coeficiente de determinación R cuadrada =\", RSq)\n",
    "\n",
    "#R2 ajustada\n",
    "n = x.shape[0]\n",
    "p = x.shape[1]\n",
    "\n",
    "RSqAj = 1 - (RSS/(n-p))/(TSS/(n-1))\n",
    "print(\"Coeficiente de determinación R cuadrada ajustada =\", RSqAj)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "704c7ad6-59e9-41ab-a51e-cee444989802",
   "metadata": {},
   "source": [
    "Debido a que algunas variables en esta base de datos tienen dependencia exacta, la matriz X_XT no tiene inversa, y los valores de los coeficientes salen enormes, lo que provoca que los residuales se disparen.\n",
    "\n",
    "Se procede a eliminar las variables de \"sqft_above\" y \"sqft_basement\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 124,
   "id": "97559733-710b-4508-82e9-357476efc6ef",
   "metadata": {},
